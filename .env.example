# 阿里云 DashScope API Key（从阿里云控制台获取）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 腾讯云 MCP SSE 接入 Token（完整端点路径，从腾讯云 MCP 控制台获取）
TENCENT_MCP_SSE_ENDPOINT=/sse/your_token_here

# 高德地图 API Key（从高德开放平台获取）
AMAP_API_KEY=your_amap_api_key_here

# map_server.py 的绝对路径（修改为你本机的实际路径）
MAP_SERVER_PATH=/path/to/your/project/mcp-server/map_server.py

# MinIO 存储凭证（本地开发默认值，生产环境请修改）
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
